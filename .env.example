# Local dev: apps run on the host via `bun run dev`. Start infra with `bun run dev:infra`.
# For the full Docker stack, use `bun run docker:build:up` — compose uses internal service hostnames
# (postgres, redis, twilio-mock); the localhost URLs below apply only to host-run dev.

# --- Infrastructure (Postgres + Redis) ---
POSTGRES_DB=sms_system
POSTGRES_USER=sms
POSTGRES_PASSWORD=sms
DATABASE_URL=postgres://sms:sms@localhost:5432/sms_system
REDIS_URL=redis://localhost:6379

# --- API ---
API_PORT=3000
CORS_ORIGIN=http://localhost:5173

# --- Worker ---
TWILIO_BASE_URL=http://localhost:3002
TWILIO_ACCOUNT_SID=AC_mock_account
PROCESSING_DELAY_MIN_MS=3000
PROCESSING_DELAY_MAX_MS=15000
# Set to a small value such as 100 for fast local demos/tests.
TEST_PROCESSING_DELAY_MS=
WORKER_CONCURRENCY=5

# --- Twilio mock ---
TWILIO_MOCK_PORT=3002
API_WEBHOOK_URL=http://localhost:3000/webhook/twilio
TWILIO_FROM_NUMBER=+15551230000

# --- Frontend ---
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:3000
VITE_TWILIO_MOCK_BASE_URL=http://localhost:3002
