    "db:setup": "bun --env-file=../../.env src/db/setup.ts"
  },
  "dependencies": {
    "@hono/zod-validator": "0.8.0",
    "@sms/shared": "workspace:*",
    "bullmq": "5.77.6",
    "hono": "4.12.23",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/bun": "1.3.14"
  }
}
